# 售前CRM系统 v3 环境变量配置
# 复制此文件为 .env 并填入你的配置

# JWT 密钥（必填，请修改为随机字符串）
SECRET_KEY=your-secret-key-here

# 管理员默认账号（首次启动时创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# PostgreSQL 数据库
POSTGRES_USER=crm
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=crm
DATABASE_URL=postgresql://crm:your-db-password@crm-db:5432/crm

# Redis 缓存
REDIS_URL=redis://crm-redis:6379/0

# AI 模型（可选，也可在前端页面配置）
DEEPSEEK_API_KEY=

# 时区
TZ=Asia/Shanghai
